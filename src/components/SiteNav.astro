      <svg class="logo-glyph" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 22 6 A 10 10 0 1 0 22 26 A 8 8 0 1 1 22 6 Z" fill="currentColor"></path>
        <path d="M 10 10 L 10.8 12.2 L 13 13 L 10.8 13.8 L 10 16 L 9.2 13.8 L 7 13 L 9.2 12.2 Z" fill="var(--gold)"></path>
      </svg>
      I Had This Dream
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/#interpret" class:list={[{ active: active === "interpret" }]}>Interpret</a>
      <a href="/#common" class:list={[{ active: active === "common" }]}>Common Dreams</a>
      <a href="/symbols" class:list={[{ active: active === "symbols" }]}>Symbols</a>
      <a href="/#journal" class:list={[{ active: active === "journal" }]}>Journal</a>
      <a href="/#faq" class:list={[{ active: active === "faq" }]}>FAQ</a>
