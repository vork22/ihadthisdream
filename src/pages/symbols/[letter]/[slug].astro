---
import Base from "~/layouts/Base.astro";
import SiteNav from "~/components/SiteNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import Tweaks from "~/components/Tweaks.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import TLDR from "~/components/TLDR.astro";
import CitedWorks from "~/components/CitedWorks.astro";
import PageFAQ from "~/components/PageFAQ.astro";
import JournalPrompts from "~/components/JournalPrompts.astro";
import { getCollection, render } from "astro:content";
import { symbolTitle, symbolPath, dreamPath, variationPath } from "~/lib/site";
import { graph, breadcrumbSchema, definedTermSchema, articleSchema, faqSchema } from "~/lib/schema";

export async function getStaticPaths() {
  const symbols = await getCollection("symbols");
  return symbols.map((s) => ({
    params: {
      letter: s.data.letter.toLowerCase(),
      slug: s.id.replace(/\.md$/, ""),
    },
    props: { symbol: s },
  }));
}

const { symbol } = Astro.props;
const { Content } = await render(symbol);

const slug = symbol.id.replace(/\.md$/, "");
const url = symbolPath(symbol.data.letter, slug);
const title = symbolTitle(symbol.data.term);
const metaDescription =
  symbol.data.metaDescription ??
  `${symbol.data.term} dream meaning & symbolism — Jungian, Freudian, Vedic, Sufi & Indigenous readings, with cited primary sources. Free, scholarly, no signup.`;
const description = symbol.data.gloss;

const allVariations = await getCollection("symbolVariations");
const variations = allVariations
  .filter(
    (v) =>
      v.data.parentSymbol.toLowerCase() === symbol.data.term.toLowerCase(),
  )
  .sort((a, b) => a.data.label.localeCompare(b.data.label));

const allSymbols = await getCollection("symbols");
const related = symbol.data.related
  .map((name) =>
    allSymbols.find((s) => s.data.term.toLowerCase() === name.toLowerCase()),
  )
  .filter(Boolean) as typeof allSymbols;

// Find common dreams referencing this symbol
const allDreams = await getCollection("dreams");
const relatedDreams = allDreams.filter((d) =>
  (d.data.relatedSymbols ?? []).some(
    (s) => s.toLowerCase() === symbol.data.term.toLowerCase(),
  ) ||
  (d.body ?? "").toLowerCase().includes(symbol.data.term.toLowerCase()),
).slice(0, 3);

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Symbols", url: "/symbols" },
  { name: symbol.data.letter.toUpperCase(), url: `/symbols#letter-${symbol.data.letter.toUpperCase()}` },
  { name: symbol.data.term, url },
];

const jsonLd = graph(
  breadcrumbSchema(breadcrumbs),
  definedTermSchema({
    term: symbol.data.term,
    description: symbol.data.gloss,
    url,
    image: symbol.data.image,
    citationIds: symbol.data.citations,
  }),
  articleSchema({
    headline: `${symbol.data.term} in Dreams: Meaning & Symbolism`,
    description: metaDescription,
    url,
    image: symbol.data.image,
    datePublished: symbol.data.datePublished,
    dateModified: symbol.data.dateModified ?? symbol.data.datePublished,
    keywords: [
      `${symbol.data.term} dream meaning`,
      `${symbol.data.term} symbolism`,
      `${symbol.data.term} in dreams`,
      ...symbol.data.themes,
    ],
    articleSection: "Dream Symbols",
    about: symbol.data.themes,
    citationIds: symbol.data.citations,
  }),
  symbol.data.faqs && symbol.data.faqs.length > 0
    ? faqSchema(symbol.data.faqs)
    : null,
);
---

<Base
  title={title}
  description={metaDescription}
  ogImage={symbol.data.image ?? undefined}
  ogType="article"
  jsonLd={jsonLd}
  publishedTime={symbol.data.datePublished}
  modifiedTime={symbol.data.dateModified ?? symbol.data.datePublished}
  articleSection="Dream Symbols"
  keywords={[
    `${symbol.data.term} dream meaning`,
    `${symbol.data.term} symbolism`,
    `${symbol.data.term} in dreams`,
  ]}
>
  <SiteNav active="symbols" />

  <main class="container" style="padding-top: 40px; padding-bottom: 96px; max-width: 760px;">
    <Breadcrumbs items={breadcrumbs} />

    {
      symbol.data.image && (
        <img
          class="symbol-hero"
          src={symbol.data.image}
          alt={`Woodcut illustration of ${symbol.data.term}, a dream symbol`}
          width="320"
          height="320"
          loading="eager"
          decoding="async"
        />
      )
    }

    <h1
      style="font-size: clamp(48px, 7vw, 80px); font-weight: 400; margin-bottom: 16px; text-wrap: balance; letter-spacing: -0.02em;"
    >
      {symbol.data.term}
    </h1>

    <p
      style="font-family: var(--display); font-size: 22px; font-style: italic; color: var(--peach-deep); margin-bottom: 24px; text-wrap: pretty;"
    >
      {symbol.data.gloss}
    </p>

    {
      symbol.data.traditions.length > 0 && (
        <div class="dream-card-themes" style="margin-bottom: 32px;">
          {symbol.data.traditions.map((t) => <span>{t}</span>)}
        </div>
      )
    }

    {
      symbol.data.tldr && (
        <TLDR>
          {symbol.data.tldr}
        </TLDR>
      )
    }

    <div class="analysis-body" style="font-size: 19px;">
      <Content />
    </div>

    {
      symbol.data.journalPrompts && symbol.data.journalPrompts.length > 0 && (
        <JournalPrompts
          prompts={symbol.data.journalPrompts}
          term={symbol.data.term}
        />
      )
    }

    {
      variations.length > 0 && (
        <div style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--line);">
          <div class="tweak-label" style="margin-bottom: 16px;">
            {symbol.data.term} in dreams: common variations
          </div>
          <ul
            style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px;"
          >
            {variations.map((v) => (
              <li>
                <a
                  href={variationPath(symbol.data.letter, slug, v.data.slug)}
                  style="display: block; padding: 12px 16px; border: 1px solid var(--line); border-radius: 8px; background: var(--bg); color: inherit; text-decoration: none;"
                >
                  <strong style="font-family: var(--display);">
                    {symbol.data.term} {v.data.label}
                  </strong>
                  <div style="color: var(--ink-soft); font-size: 14px; margin-top: 4px;">
                    {v.data.gloss}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      symbol.data.themes.length > 0 && (
        <div style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--line);">
          <div class="tweak-label" style="margin-bottom: 12px;">Themes</div>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {symbol.data.themes.map((t) => (
              <a class="chip" href={`/tags/${t.replace(/\s+/g, "-").toLowerCase()}`}>
                {t}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      related.length > 0 && (
        <div style="margin-top: 40px;">
          <div class="tweak-label" style="margin-bottom: 16px;">Related symbols</div>
          <div class="related-symbol-grid">
            {related.map((r) => (
              <a
                href={`/symbols/${r.data.letter.toLowerCase()}/${r.id.replace(/\.md$/, "")}`}
                class="related-symbol"
              >
                {r.data.image && (
                  <img
                    src={r.data.image}
                    alt={`Woodcut of ${r.data.term}`}
                    loading="lazy"
                    decoding="async"
                    width="72"
                    height="72"
                  />
                )}
                <span>{r.data.term}</span>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      relatedDreams.length > 0 && (
        <div style="margin-top: 40px;">
          <div class="tweak-label" style="margin-bottom: 16px;">
            Common dreams featuring {symbol.data.term.toLowerCase()}
          </div>
          <div class="dreams-grid">
            {relatedDreams.map((d) => (
              <a href={dreamPath(d.data.slug)} class="dream-card">
                <div class="dream-card-title">{d.data.title}</div>
                <div class="dream-card-one">{d.data.excerpt}</div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      symbol.data.faqs && symbol.data.faqs.length > 0 && (
        <PageFAQ items={symbol.data.faqs} />
      )
    }

    {
      symbol.data.citations && symbol.data.citations.length > 0 && (
        <CitedWorks ids={symbol.data.citations} />
      )
    }

    <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--line); display: flex; gap: 16px; flex-wrap: wrap;">
      <a href="/#interpret" class="btn">
        Interpret a dream with this symbol
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </a>
      <a href="/methodology" class="btn btn-ghost">
        How these readings are sourced
      </a>
    </div>
  </main>

  <SiteFooter />
  <Tweaks />
</Base>
