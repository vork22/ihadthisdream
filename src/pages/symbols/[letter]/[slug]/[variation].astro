---
import Base from "~/layouts/Base.astro";
import SiteNav from "~/components/SiteNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import Tweaks from "~/components/Tweaks.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import TLDR from "~/components/TLDR.astro";
import CitedWorks from "~/components/CitedWorks.astro";
import PageFAQ from "~/components/PageFAQ.astro";
import JournalPrompts from "~/components/JournalPrompts.astro";
import { getCollection, render } from "astro:content";
import {
  variationTitle,
  variationPath,
  symbolPath,
} from "~/lib/site";
import {
  graph,
  breadcrumbSchema,
  articleSchema,
  faqSchema,
} from "~/lib/schema";

export async function getStaticPaths() {
  const variations = await getCollection("symbolVariations");
  const symbols = await getCollection("symbols");

  const out: { params: Record<string, string>; props: Record<string, unknown> }[] = [];
  for (const v of variations) {
    const parent = symbols.find(
      (s) => s.data.term.toLowerCase() === v.data.parentSymbol.toLowerCase(),
    );
    if (!parent) continue;
    out.push({
      params: {
        letter: parent.data.letter.toLowerCase(),
        slug: parent.id.replace(/\.md$/, ""),
        variation: v.data.slug,
      },
      props: { variation: v, parent },
    });
  }
  return out;
}

const { variation, parent } = Astro.props;
const { Content } = await render(variation);

const parentSlug = parent.id.replace(/\.md$/, "");
const url = variationPath(parent.data.letter, parentSlug, variation.data.slug);
const parentUrl = symbolPath(parent.data.letter, parentSlug);
const headline = `${parent.data.term} ${variation.data.label} in Dreams`;
const title = variationTitle(parent.data.term, variation.data.label);
const metaDescription =
  variation.data.metaDescription ??
  `${parent.data.term} ${variation.data.label.toLowerCase()} in dreams — meaning, symbolism, and traditional readings (Jungian, Freudian, Vedic, Sufi). Cited primary sources, no signup.`;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Symbols", url: "/symbols" },
  {
    name: parent.data.letter.toUpperCase(),
    url: `/symbols#letter-${parent.data.letter.toUpperCase()}`,
  },
  { name: parent.data.term, url: parentUrl },
  { name: variation.data.label, url },
];

const allVariations = await getCollection("symbolVariations");
const siblings = allVariations
  .filter(
    (v) =>
      v.data.parentSymbol.toLowerCase() === parent.data.term.toLowerCase() &&
      v.data.slug !== variation.data.slug,
  )
  .slice(0, 8);

const jsonLd = graph(
  breadcrumbSchema(breadcrumbs),
  articleSchema({
    headline,
    description: metaDescription,
    url,
    image: parent.data.image,
    datePublished: variation.data.datePublished,
    dateModified:
      variation.data.dateModified ?? variation.data.datePublished,
    keywords: [
      `${parent.data.term} ${variation.data.label.toLowerCase()} dream meaning`,
      `dream of ${parent.data.term.toLowerCase()} ${variation.data.label.toLowerCase()}`,
      `${parent.data.term.toLowerCase()} dream interpretation`,
    ],
    articleSection: "Symbol variation",
    citationIds: variation.data.citations,
  }),
  variation.data.faqs && variation.data.faqs.length > 0
    ? faqSchema(variation.data.faqs)
    : null,
);
---

<Base
  title={title}
  description={metaDescription}
  ogImage={parent.data.image ?? undefined}
  ogType="article"
  jsonLd={jsonLd}
  publishedTime={variation.data.datePublished}
  modifiedTime={variation.data.dateModified ?? variation.data.datePublished}
  articleSection="Symbol variation"
>
  <SiteNav />

  <main
    class="container"
    style="padding-top: 40px; padding-bottom: 96px; max-width: 760px;"
  >
    <Breadcrumbs items={breadcrumbs} />

    <div class="eyebrow" style="justify-content: flex-start;">
      <a href={parentUrl} style="color: inherit;">{parent.data.term}</a>
      <span style="margin: 0 8px; opacity: 0.5;">·</span>
      <span>{variation.data.label}</span>
    </div>

    <h1
      style="font-size: clamp(36px, 5.5vw, 56px); margin-bottom: 16px; font-weight: 400; letter-spacing: -0.02em; text-wrap: balance;"
    >
      {parent.data.term}: {variation.data.label} in Dreams
    </h1>

    <p
      style="font-family: var(--display); font-size: 21px; font-style: italic; color: var(--peach-deep); margin-bottom: 32px; text-wrap: pretty;"
    >
      {variation.data.gloss}
    </p>

    {variation.data.tldr && <TLDR text={variation.data.tldr} />}

    <div class="analysis-body" style="font-size: 19px;">
      <Content />
    </div>

    {variation.data.journalPrompts && variation.data.journalPrompts.length > 0 && (
      <JournalPrompts prompts={variation.data.journalPrompts} />
    )}

    {variation.data.faqs && variation.data.faqs.length > 0 && (
      <PageFAQ items={variation.data.faqs} />
    )}

    {variation.data.citations && variation.data.citations.length > 0 && (
      <CitedWorks ids={variation.data.citations} />
    )}

    {siblings.length > 0 && (
      <div
        style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--line);"
      >
        <div class="tweak-label" style="margin-bottom: 16px;">
          More {parent.data.term.toLowerCase()} variations
        </div>
        <ul
          style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px;"
        >
          {siblings.map((s) => (
            <li>
              <a
                href={variationPath(parent.data.letter, parentSlug, s.data.slug)}
                style="display: block; padding: 12px 16px; border: 1px solid var(--line); border-radius: 8px; background: var(--bg); color: inherit; text-decoration: none;"
              >
                <strong style="font-family: var(--display);">
                  {parent.data.term} {s.data.label}
                </strong>
                <div style="color: var(--ink-soft); font-size: 14px; margin-top: 4px;">
                  {s.data.gloss}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div
      style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--line); display: flex; gap: 16px; flex-wrap: wrap;"
    >
      <a href={parentUrl} class="btn btn-ghost">
        ← Back to {parent.data.term}
      </a>
      <a href="/#interpret" class="btn">Interpret a dream</a>
    </div>
  </main>

  <SiteFooter />
  <Tweaks />
</Base>
