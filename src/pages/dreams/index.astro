---
import Base from "~/layouts/Base.astro";
import SiteNav from "~/components/SiteNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import Tweaks from "~/components/Tweaks.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { graph, breadcrumbSchema, collectionPageSchema } from "~/lib/schema";
import { pageTitle, dreamPath } from "~/lib/site";

const dreams = await getCollection("dreams");
dreams.sort((a, b) => a.data.title.localeCompare(b.data.title));

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Common dreams", url: "/dreams" },
];

const traditions = Array.from(
  new Set(dreams.flatMap((d) => d.data.traditions)),
).sort();

const jsonLd = graph(
  breadcrumbSchema(breadcrumbs),
  collectionPageSchema({
    name: "Common dreams and what they mean",
    description:
      "Scholarly meanings for the 24 most-recurring dreams: falling, flying, teeth falling out, being chased, water, snakes, the dead. Cross-tradition readings.",
    url: "/dreams",
    items: dreams.map((d) => ({
      name: d.data.title,
      url: dreamPath(d.data.slug),
    })),
  }),
);
---

<Base
  title={pageTitle("Common Dreams: 24 Recurring Dreams Explained")}
  description="Scholarly meanings for the 24 most-recurring dreams — falling, flying, teeth, being chased, water, snakes, the dead — read across Jung, Freud, Vedic, Sufi, and Indigenous traditions."
  jsonLd={jsonLd}
>
  <SiteNav active="common" />

  <main class="container" style="padding-top: 40px; padding-bottom: 96px;">
    <Breadcrumbs items={breadcrumbs} />

    <div class="eyebrow" style="justify-content: flex-start;">Common dreams</div>
    <h1 style="font-size: clamp(40px, 6vw, 64px); margin-bottom: 16px; font-weight: 400; letter-spacing: -0.02em;">
      The {dreams.length} dreams <em style="color: var(--lav-deep); font-style: italic;">we keep having</em>.
    </h1>
    <p class="hero-lede" style="margin-bottom: 32px;">
      The recurrence list — falling, flying, teeth, being chased, the dead.
      Each entry below is read tradition by tradition (Jung, Freud, Vedic,
      Sufi, Indigenous), with cited primary sources.
    </p>

    {traditions.length > 0 && (
      <div class="symbols-controls" style="margin-bottom: 32px;">
        <button class="chip" data-tradition-filter="" style="background: var(--lav); color: #fff;">All</button>
        {traditions.map((t) => (
          <button class="chip" data-tradition-filter={t}>{t}</button>
        ))}
      </div>
    )}

    <div class="dreams-grid">
      {dreams.map((d, i) => (
        <a
          href={dreamPath(d.data.slug)}
          class="dream-card"
          data-traditions={d.data.traditions.join("|").toLowerCase()}
        >
          <div class="dream-card-num">№ {String(i + 1).padStart(2, "0")}</div>
          <div class="dream-card-title">{d.data.title}</div>
          <div class="dream-card-one">{d.data.excerpt}</div>
          {d.data.traditions.length > 0 && (
            <div class="dream-card-themes">
              {d.data.traditions.slice(0, 3).map((t) => (
                <span>{t}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </main>

  <SiteFooter />
  <Tweaks />

  <script is:inline>
    (function () {
      const chips = Array.from(document.querySelectorAll("[data-tradition-filter]"));
      const cards = Array.from(document.querySelectorAll(".dream-card[data-traditions]"));
      let active = "";
      function apply() {
        const t = active.toLowerCase();
        cards.forEach((c) => {
          const ts = (c.dataset.traditions || "").split("|");
          c.style.display = !t || ts.includes(t) ? "" : "none";
        });
      }
      chips.forEach((c) =>
        c.addEventListener("click", () => {
          active = c.dataset.traditionFilter || "";
          chips.forEach((other) => {
            const on = other.dataset.traditionFilter === active;
            other.style.background = on ? "var(--lav)" : "";
            other.style.color = on ? "#fff" : "";
          });
          apply();
        }),
      );
    })();
  </script>
</Base>
