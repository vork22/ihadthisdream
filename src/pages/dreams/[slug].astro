---
import Base from "~/layouts/Base.astro";
import SiteNav from "~/components/SiteNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import Tweaks from "~/components/Tweaks.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const dreams = await getCollection("dreams");
  return dreams.map((d) => ({ params: { slug: d.data.slug }, props: { dream: d } }));
}

const { dream } = Astro.props;
const { Content } = await render(dream);

const title = `${dream.data.title} — Dream Meaning & Symbolism | I Had This Dream`;
const description = dream.data.excerpt;

// Auto-match symbols mentioned in this dream's body/title/excerpt so we can
// illustrate the entry with the right woodcuts, even when the frontmatter's
// relatedSymbols array is empty.
const allSymbolsForMatching = await getCollection("symbols");
const haystack = [
  dream.data.title,
  dream.data.excerpt,
  dream.body ?? "",
  dream.data.slug,
]
  .join(" \n ")
  .toLowerCase();

function escapeRegex(s: string): string {
  return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

const matched: Array<{
  entry: (typeof allSymbolsForMatching)[number];
  firstIndex: number;
}> = [];

for (const s of allSymbolsForMatching) {
  const term = s.data.term.toLowerCase();
  if (term.length < 3) continue;
  const re = new RegExp(`\\b${escapeRegex(term)}s?\\b`, "i");
  const m = haystack.match(re);
  if (m && typeof m.index === "number") {
    matched.push({ entry: s, firstIndex: m.index });
  }
}

const dreamSymbols = matched
  .sort((a, b) => a.firstIndex - b.firstIndex)
  .map((m) => m.entry)
  .slice(0, 8);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: dream.data.title,
  description,
  mainEntityOfPage: `https://ihadthisdream.com/dreams/${dream.data.slug}`,
  about: dream.data.traditions.map((t) => ({
    "@type": "Thing",
    name: `${t} dream tradition`,
  })),
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <SiteNav active="common" />

  <main class="container" style="padding-top: 56px; padding-bottom: 96px; max-width: 760px;">
    <div class="eyebrow" style="justify-content: flex-start;">
      <a href="/#common" style="color: inherit;">Common dreams</a>
    </div>
    <h1 style="font-size: clamp(36px, 5vw, 56px); margin-bottom: 20px; text-wrap: balance;">
      {dream.data.title}
    </h1>
    <p
      style="font-family: var(--display); font-size: 22px; font-style: italic; color: var(--peach-deep); margin-bottom: 32px; text-wrap: pretty;"
    >
      {dream.data.excerpt}
    </p>

    {
      dream.data.traditions.length > 0 && (
        <div class="dream-card-themes" style="margin-bottom: 32px;">
          {dream.data.traditions.map((t) => <span>{t}</span>)}
        </div>
      )
    }

    <div class="analysis-body" style="font-size: 19px;">
      <Content />
    </div>

    {
      dreamSymbols.length > 0 && (
        <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--line);">
          <div class="tweak-label" style="margin-bottom: 16px;">Symbols in this dream</div>
          <div class="related-symbol-grid">
            {dreamSymbols.map((r) => (
              <a
                href={`/symbols/${r.data.letter.toLowerCase()}/${r.id.replace(/\.md$/, "")}`}
                class="related-symbol"
              >
                {r.data.image && (
                  <img
                    src={r.data.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="72"
                    height="72"
                  />
                )}
                <span>{r.data.term}</span>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--line);">
      <a href="/#interpret" class="btn">
        Interpret your own dream
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
  </main>

  <SiteFooter />
  <Tweaks />
</Base>
