---
import Base from "~/layouts/Base.astro";
import SiteNav from "~/components/SiteNav.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import Tweaks from "~/components/Tweaks.astro";
import FAQ from "~/components/FAQ.astro";
import SymbolGallery from "~/components/SymbolGallery.astro";
import DreamChat from "~/components/DreamChat.tsx";
import JournalPane from "~/components/JournalPane.tsx";
import { getCollection } from "astro:content";

const commonDreams = await getCollection("dreams");
commonDreams.sort((a, b) => a.data.title.localeCompare(b.data.title));

const symbols = await getCollection("symbols");
const letters = Array.from(
  new Set(symbols.map((s) => s.data.letter.toUpperCase())),
).sort();
---

<Base>
  <SiteNav active="interpret" />

  <main id="top">
    <!-- HERO + DREAM CHAT -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-copy">
            <div class="eyebrow">A scholarly dream interpreter</div>
            <h1 class="hero-title">Tell me your <em>dream</em>.</h1>
            <p class="hero-lede">
              However much you remember — a single image or the whole strange
              story — is enough. Receive a careful, scholarly interpretation
              drawing on Jung, Freud, Vedic tradition, and Indigenous
              dream-lore.
            </p>
            <div id="interpret" class="hero-pad">
              <DreamChat client:visible />
            </div>
          </div>
          <div class="hero-etching">
            <img
              src="/assets/hero-woodcut.png"
              alt="A hand-carved woodcut of a sleeping moon-sun face with rays, stars, and clouds."
              loading="eager"
              width="400"
              height="540"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- COMMON DREAMS -->
    <section id="common" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Common dreams and <em>what they often mean</em>.</h2>
          <p>
            Starting places — not verdicts. Each entry draws on scholarship
            from multiple traditions and points to related symbols.
          </p>
        </div>
        <div class="dreams-grid">
          {
            commonDreams.slice(0, 24).map((d, i) => (
              <a href={`/dreams/${d.data.slug}`} class="dream-card">
                <div class="dream-card-num">
                  № {String(i + 1).padStart(2, "0")}
                </div>
                <div class="dream-card-title">{d.data.title}</div>
                <div class="dream-card-one">{d.data.excerpt}</div>
                {d.data.traditions.length > 0 && (
                  <div class="dream-card-themes">
                    {d.data.traditions.slice(0, 3).map((t) => (
                      <span>{t}</span>
                    ))}
                  </div>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- SYMBOLS TEASER -->
    <section id="symbols" class="section">
      <div class="container">
        <div class="section-head">
          <h2>An A–Z of <em>dream symbols</em>.</h2>
          <p>
            {symbols.length} entries across animals, celestial bodies,
            archetypes, body, objects, actions, and nature.
          </p>
        </div>
        <SymbolGallery />
        <div class="letter-nav" style="margin: 24px 0 8px; justify-content: center;">
          {letters.map((l) => <a href={`/symbols#letter-${l}`}>{l}</a>)}
        </div>
        <p style="text-align: center; margin-top: 24px;">
          <a href="/symbols" class="btn btn-ghost">
            Browse the full dictionary
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
            </svg>
          </a>
        </p>
      </div>
    </section>

    <!-- JOURNAL -->
    <section id="journal" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Your private <em>dream journal</em>.</h2>
          <p>
            Everything you save stays on your device — nothing is sent
            anywhere. Export your journal as JSON any time.
          </p>
        </div>
        <JournalPane client:only="react" />
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Questions <em>often asked</em>.</h2>
          <p>Short answers. Fuller threads live in the interpreter itself.</p>
        </div>
        <FAQ />
      </div>
    </section>
  </main>

  <SiteFooter />
  <Tweaks />
</Base>
